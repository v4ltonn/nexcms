# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/nexcms

# ── Site identity (whitelabel these for your deployment) ─────────────────────
SITE_URL=https://yourdomain.com
SITE_DOMAIN=yourdomain.com
SITE_NAME=NexCMS

# ── Auth secrets — generate with: openssl rand -hex 64 ───────────────────────
SESSION_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_64

# ── Admin account (set on first run, then remove from env) ───────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Optional integrations ────────────────────────────────────────────────────

# Analytics (self-hosted Umami or similar)
# ANALYTICS_URL=https://analytics.yourdomain.com
# ANALYTICS_WEBSITE_ID=your-website-id

# Telegram notifications
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHANNEL=@yourchannel

# IndexNow (Bing/Yandex instant indexing)
# INDEXNOW_KEY=your-indexnow-key

# Google Search Console
# GOOGLE_CLIENT_EMAIL=
# GOOGLE_PRIVATE_KEY=

# Local LLM for AI-enhanced content (Ollama)
# USE_LOCAL_LLM=0
# LOCAL_LLM_URL=http://127.0.0.1:11434
# LOCAL_LLM_MODEL=llama3
